# Deployment image tag. The deployment script overwrites this on remote.
DEPLOY_TAG=predeploy-local

# First boot only. The deployment script clears this on remote after a
# successful initialization so later restarts do not re-enter install mode.
AUTO_INSTALL=true

# Host binding
ANSWER_BIND_PORT=9080

# Primary application database
DB_TYPE=postgres
DB_HOST=postgres-main:5432
DB_NAME=answer
DB_USERNAME=answer
DB_PASSWORD=change-me-answer-db-password
DB_FILE=

# Postgres backing services
POSTGRES_MAIN_DB=answer
POSTGRES_MAIN_USER=answer
POSTGRES_MAIN_PASSWORD=change-me-answer-db-password
POSTGRES_VAULT_DB=vault
POSTGRES_VAULT_USER=vault
POSTGRES_VAULT_PASSWORD=change-me-vault-db-password

# Site bootstrap
LANGUAGE=zh-CN
SITE_NAME=匿名社区预演
SITE_URL=http://127.0.0.1:9080
CONTACT_EMAIL=admin@example.local
ADMIN_NAME=admin
ADMIN_PASSWORD=ChangeMe123456
ADMIN_EMAIL=admin@example.local
EXTERNAL_CONTENT_DISPLAY=always_display
SITE_ADDR=0.0.0.0:80
LOG_LEVEL=INFO
COMMUNITY_PREVIEW_MODE=local

# WeCom. Placeholders are enough for a private predeploy bring-up, but they
# must be replaced before real OAuth/callback testing.
APP_BASE_URL=http://127.0.0.1:9080
WECOM_CORP_ID=replace-me
WECOM_AGENT_ID=replace-me
WECOM_APP_SECRET=replace-me
WECOM_CALLBACK_TOKEN=replace-me-with-real-token
WECOM_CALLBACK_AES_KEY=replace-me-with-real-43-char-aes-key
WECOM_DEFAULT_RETURN_TO=/home?tab=discussion

# Vault
VAULT_BASE_URL=http://vault-service:8091
VAULT_SHARED_TOKEN=change-me-shared-token
VAULT_SECRET=change-me-32-byte-secret
